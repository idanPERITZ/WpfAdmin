<Window x:Class="WpfAdminPeritz.OpponentStatsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#01000000"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Grid Background="Transparent">
        <Border Width="320"
                Background="#1A1A1A"
                CornerRadius="14"
                BorderBrush="#333"
                BorderThickness="1"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock x:Name="TxtName" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Wins / Draws / Losses" FontSize="11" Foreground="#777" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <TextBlock x:Name="TxtWins" FontSize="18" FontWeight="SemiBold" Foreground="#4CAF50"/>
                    <TextBlock Text=" / " Foreground="#555" FontSize="18"/>
                    <TextBlock x:Name="TxtDraws" FontSize="18" Foreground="#AAA"/>
                    <TextBlock Text=" / " Foreground="#555" FontSize="18"/>
                    <TextBlock x:Name="TxtLosses" FontSize="18" FontWeight="SemiBold" Foreground="#E53935"/>
                </StackPanel>

                <Button x:Name="BtnFriend"
        Height="Auto"
        Background="Transparent"
        FontSize="14"
        FontWeight="SemiBold"
        BorderThickness="0"
        Cursor="Hand"
        Margin="0,0,0,12"
        Click="BtnFriend_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel x:Name="InlineActions" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="Accept" Foreground="#4CAF50" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0" MouseDown="Accept_Click"/>
                    <TextBlock Text="/" Foreground="#777" Margin="0,0,6,0"/>
                    <TextBlock Text="Decline" Foreground="#E53935" FontWeight="SemiBold" Cursor="Hand" MouseDown="Decline_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>