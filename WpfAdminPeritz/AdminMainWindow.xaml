<Window x:Class="WpfAdminPeritz.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Page"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F2F3F5">

    <Window.Resources>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder"
                                        Property="Background"
                                        Value="#2C2C2C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder"
                                        Property="Background"
                                        Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0"
                Background="#111"
                Padding="15">

            <StackPanel>

                <TextBlock Text="Admin Page"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,30"/>

                <Button Content="Users"
                        Margin="0,0,0,10"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="BtnAdminList_Click"/>

                <Button Content="Games"
                        Margin="0,0,0,10"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="BtnGames_Click"/>

                <Button Content="Friends"
                        Margin="0,0,0,10"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="BtnFriends_Click"/>

            </StackPanel>
        </Border>

        <!-- ===== Content Area ===== -->
        <Border Grid.Column="1"
                Margin="0"
                Background="White"
                CornerRadius="10"
                Padding="5">

            <ContentControl x:Name="MainContent"/>

        </Border>

    </Grid>
</Window>