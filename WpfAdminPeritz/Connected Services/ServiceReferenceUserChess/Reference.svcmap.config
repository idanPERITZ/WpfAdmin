<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.serviceModel>
        <bindings>
            <wsDualHttpBinding>
                <binding name="WSDualHttpBinding_IChessServiceUser" />
            </wsDualHttpBinding>
        </bindings>
        <client>
            <endpoint address="http://localhost:8733/Design_Time_Addresses/WcfService/ChessServiceUser/"
                binding="wsDualHttpBinding" bindingConfiguration="WSDualHttpBinding_IChessServiceUser"
                contract="WpfAdminPeritz.ServiceReferenceUserChess.IChessServiceUser"
                name="WSDualHttpBinding_IChessServiceUser">
                <identity>
                    <dns value="localhost" />
                </identity>
            </endpoint>
        </client>
    </system.serviceModel>
</configuration>