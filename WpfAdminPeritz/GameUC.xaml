<UserControl x:Class="WpfAdminPeritz.GameUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="70">

    <Border Margin="6" Padding="12" Background="White"
            CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>

            <!-- עיגול עם מספר משחק -->
            <Border Grid.Column="0"
                    Width="32"
                    Height="32"
                    CornerRadius="20"
                    Background="Black"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <TextBlock Text="♟"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- פרטי משחק -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">

                <TextBlock Text="{Binding GameID, StringFormat='Game #{0}'}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111"/>

                <TextBlock Text="{Binding GameDate, StringFormat='📅 {0:dd/MM/yyyy}'}"
                           FontSize="12"
                           Foreground="#777"/>

            </StackPanel>

            <!-- כפתור View -->
            <Button Grid.Column="2"
                    Content="View"
                    Width="60"
                    Height="30"
                    Background="Black"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Button_Click">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>

            </Button>

        </Grid>
    </Border>
</UserControl>