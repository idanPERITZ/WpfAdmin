<UserControl x:Class="WpfAdminPeritz.ChessMainWindowUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAdminPeritz"
             mc:Ignorable="d" 
             Background="Black"
             d:DesignHeight="450" d:DesignWidth="975">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- OPPONENT NAME HEADER -->
        <Border Grid.Row="0" Background="#111" Padding="15,10">
            <StackPanel HorizontalAlignment="Center">
                <!-- Opponent Name -->
                <TextBlock x:Name="OpponentNameText"
                          Foreground="White"
                          FontSize="18"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Text="Playing against: "/>

                <!-- Statistics -->
                <StackPanel Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0">

                    <!-- Wins -->
                    <Border Background="#E8F5E9"
                           CornerRadius="6"
                           Padding="8,3"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="W: "
                                      FontSize="12"
                                      Foreground="#2E7D32"
                                      FontWeight="Bold"/>
                            <TextBlock x:Name="TxtOpponentWins"
                                      Text="0"
                                      FontSize="12"
                                      Foreground="#2E7D32"
                                      FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Draws -->
                    <Border Background="#F5F5F5"
                           CornerRadius="6"
                           Padding="8,3"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="D: "
                                      FontSize="12"
                                      Foreground="#616161"
                                      FontWeight="Bold"/>
                            <TextBlock x:Name="TxtOpponentDraws"
                                      Text="0"
                                      FontSize="12"
                                      Foreground="#616161"
                                      FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Losses -->
                    <Border Background="#FFEBEE"
                           CornerRadius="6"
                           Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="L: "
                                      FontSize="12"
                                      Foreground="#C62828"
                                      FontWeight="Bold"/>
                            <TextBlock x:Name="TxtOpponentLosses"
                                      Text="0"
                                      FontSize="12"
                                      Foreground="#C62828"
                                      FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="600"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE : CHESS BOARD -->
            <Viewbox Grid.Column="0">
                <Grid x:Name="BoardGrid"
                          Width="600"
                          Height="600"
                          MouseDown="BoardGrid_MouseDown">
                    <Grid.Background>
                        <ImageBrush ImageSource="/Assets/Board.png"/>
                    </Grid.Background>
                    <UniformGrid x:Name="HighlightGrid" Rows="8" Columns="8"/>
                    <UniformGrid x:Name="PieceGrid" Rows="8" Columns="8"
                                     RenderOptions.BitmapScalingMode="HighQuality"/>
                    <ContentControl x:Name="MenuContainer"/>
                </Grid>
            </Viewbox>

            <!-- RIGHT SIDE : MOVE HISTORY -->
            <Border Grid.Column="1"
                        Background="#1E1E1E"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Move History"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Center"/>

                    <ListView Grid.Row="1"
                                  x:Name="MoveHistoryList"
                                  ItemsSource="{Binding MoveHistory}"
                                  Background="#1E1E1E"
                                  Foreground="White"
                                  BorderThickness="0"
                                  SelectionMode="Single"
                                  SelectionChanged="MoveHistoryList_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="40" DisplayMemberBinding="{Binding MoveNumber}"/>
                                <GridViewColumn Header="White" Width="100" DisplayMemberBinding="{Binding WhiteMove}"/>
                                <GridViewColumn Header="Black" Width="100" DisplayMemberBinding="{Binding BlackMove}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- NAVIGATION BUTTONS -->
                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,8,0,0">
                        <Button Content="|◀" Height="38" Margin="2" Background="#2A2A2A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="16" Click="BtnFirst_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="◀" Height="38" Margin="2" Background="#2A2A2A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="16" Click="BtnPrev_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="▶" Height="38" Margin="2" Background="#2A2A2A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="16" Click="BtnNext_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="▶|" Height="38" Margin="2" Background="#2A2A2A" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="16" Click="BtnLast_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </UniformGrid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>