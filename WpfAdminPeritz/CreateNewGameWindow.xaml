<Window x:Class="WpfAdminPeritz.CreateNewGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Game"
        Height="515" Width="440"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ===== Section label ===== -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#777777" />
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>

        <!-- ===== Color choice (equal-size circles, constant ring) ===== -->
        <Style x:Key="ColorOptionStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel>
                            <Grid Width="78" Height="78" HorizontalAlignment="Center">
                                <Ellipse x:Name="Ring" Width="76" Height="76"
                                         Stroke="#3A3A3A" StrokeThickness="3" />
                                <Ellipse Width="54" Height="54"
                                         Fill="{TemplateBinding Background}"
                                         Stroke="#6A6A6A" StrokeThickness="1.5" />
                            </Grid>
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#888888" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="#555555" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White" />
                                <Setter TargetName="Label" Property="Foreground" Value="White" />
                                <Setter TargetName="Label" Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox items (dropdown) ===== -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Margin="6,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#262626" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#333333" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox item template ===== -->
        <DataTemplate x:Key="ComboBoxItemTemplate">
            <TextBlock Text="{Binding UserName}" 
                       Foreground="White"
                       VerticalAlignment="Center" />
        </DataTemplate>

        <!-- ===== ComboBox (closed control) ===== -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#161616" />
            <Setter Property="BorderBrush" Value="#2A2A2A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="52" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="ItemTemplate" Value="{StaticResource ComboBoxItemTemplate}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="12" />

                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{StaticResource ComboBoxItemTemplate}"
                                              Margin="18,0,42,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="White" />

                            <Path x:Name="Arrow"
                                  Data="M 0 0 L 5 5 L 10 0"
                                  Stroke="#888888"
                                  StrokeThickness="1.6"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0"
                                  IsHitTestVisible="False" />

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   StaysOpen="False"
                                   PopupAnimation="Slide">
                                <Border Background="#161616"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1.5"
                                        CornerRadius="12"
                                        Margin="0,6,0,8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.6" />
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True" Margin="0,6" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#444444" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Primary button ===== -->
        <Style x:Key="InviteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.12" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E6E6E6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CFCFCF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- SETUP GRID -->
        <Grid x:Name="SetupGrid" Visibility="Visible">
            <Grid Margin="40,32,40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- 0 header -->
                    <RowDefinition Height="26" />
                    <!-- 1 -->
                    <RowDefinition Height="Auto" />
                    <!-- 2 opponent label -->
                    <RowDefinition Height="8" />
                    <!-- 3 -->
                    <RowDefinition Height="Auto" />
                    <!-- 4 combo -->
                    <RowDefinition Height="26" />
                    <!-- 5 -->
                    <RowDefinition Height="Auto" />
                    <!-- 6 color label -->
                    <RowDefinition Height="16" />
                    <!-- 7 -->
                    <RowDefinition Height="Auto" />
                    <!-- 8 color options -->
                    <RowDefinition Height="28" />
                    <!-- 9 -->
                    <RowDefinition Height="Auto" />
                    <!-- 10 button -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="New Game" FontSize="28" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Challenge an opponent to a match"
                               FontSize="14" Foreground="#888888" Margin="0,4,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="2" Text="OPPONENT" Style="{StaticResource SectionLabelStyle}" />
                <ComboBox Grid.Row="4" x:Name="ComboOpponent"
                          Style="{StaticResource DarkComboBoxStyle}" DisplayMemberPath="UserName" />

                <TextBlock Grid.Row="6" Text="YOUR COLOR" Style="{StaticResource SectionLabelStyle}"
                           HorizontalAlignment="Center" />

                <Grid Grid.Row="8" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <RadioButton x:Name="RadioWhite" Grid.Column="0" GroupName="ColorGroup"
                                 IsChecked="True" Content="White" Background="White"
                                 Style="{StaticResource ColorOptionStyle}" />

                    <TextBlock Grid.Column="1" Text="/" FontSize="30" FontWeight="Light"
                               Foreground="#555555" HorizontalAlignment="Center"
                               VerticalAlignment="Top" Margin="0,22,0,0" />

                    <RadioButton x:Name="RadioBlack" Grid.Column="2" GroupName="ColorGroup"
                                 Content="Black" Background="#0D0D0D"
                                 Style="{StaticResource ColorOptionStyle}" />
                </Grid>

                <Button Grid.Row="10" x:Name="BtnCreateGame" Content="Send Invitation"
                        Width="180"
                        Style="{StaticResource InviteButtonStyle}" Click="BtnCreateGame_Click" />
            </Grid>
        </Grid>

        <!-- INVITATION RECEIVED GRID -->
        <Grid x:Name="InvitationGrid" Visibility="Collapsed" Background="#0D0D0D">
            <Grid Margin="40,32,40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- 0 header -->
                    <RowDefinition Height="*" />
                    <!-- 1 message card -->
                    <RowDefinition Height="28" />
                    <!-- 2 spacer -->
                    <RowDefinition Height="Auto" />
                    <!-- 3 buttons -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Game Invitation" FontSize="28" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="An opponent has challenged you to a match"
                       FontSize="14" Foreground="#888888" Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Row="1" VerticalAlignment="Center"
                Background="#161616" BorderBrush="#2A2A2A" BorderThickness="1.5"
                CornerRadius="14" Padding="26,30">
                    <StackPanel>
                        <TextBlock Text="INVITATION" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock x:Name="TxtInvitationMessage"
                           Text="You have received a game invitation!"
                           FontSize="17" FontWeight="SemiBold" Foreground="White"
                           LineHeight="28"
                           TextWrapping="Wrap" Margin="2,12,0,0" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="Decline" Grid.Column="0"
                    Style="{StaticResource InviteButtonStyle}"
                    Background="#2A2A2A" Foreground="#CCCCCC"
                    Click="BtnDecline_Click" />
                    <Button Content="Accept" Grid.Column="2"
                    Style="{StaticResource InviteButtonStyle}"
                    Click="BtnAccept_Click" />
                </Grid>
            </Grid>
        </Grid>

        <!-- ADMIN BLOCK GRID -->
        <Grid x:Name="AdminBlockGrid" Visibility="Collapsed" Background="#0D0D0D">
            <Border BorderBrush="#2A2A2A" BorderThickness="1.5" CornerRadius="16" Margin="40" Padding="30">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="80" Height="80" CornerRadius="40" Background="#1A1A1A"
                            BorderBrush="#2A2A2A" BorderThickness="1.5" Margin="0,0,0,20">
                        <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Admin cannot play games."
                               FontSize="17" FontWeight="Bold" Foreground="White"
                               TextAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock Text="Please log out and sign in as a regular player account to play."
                               FontSize="13" Foreground="#999999"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,24" />
                    <Button Content="Close" Width="200"
                            Style="{StaticResource InviteButtonStyle}"
                            Click="BtnAdminClose_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>