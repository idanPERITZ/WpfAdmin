<UserControl x:Class="WpfAdminPeritz.Friendship_UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="540"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Friendships Management"
                   Grid.Row="0"
                   Grid.ColumnSpan="3"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="10,20,0,20"/>

            <Border Grid.Row="2"
                Grid.Column="0"
                Background="White"
                CornerRadius="15"
                Padding="5"
                Margin="15,0,10,15"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <ListBox x:Name="ListBoxPlayers"
                     FontSize="15"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                     SelectionChanged="ListBoxPlayers_SelectionChanged"/>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="1"
                Background="White"
                CornerRadius="15"
                Padding="30"
                Margin="10,0,15,15"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock x:Name="SelectedPlayerName"
                               Text="Select a Player"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="12,5" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="W: " FontSize="13" Foreground="#2E7D32" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtWins" Text="0" FontSize="13" Foreground="#2E7D32" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F5F5" CornerRadius="8" Padding="12,5" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="D: " FontSize="13" Foreground="#616161" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtDraws" Text="0" FontSize="13" Foreground="#616161" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFEBEE" CornerRadius="8" Padding="12,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="L: " FontSize="13" Foreground="#C62828" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtLosses" Text="0" FontSize="13" Foreground="#C62828" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Row="1" Height="1" Fill="#EEEEEE" Margin="0,0,0,20"/>

                <TextBlock Grid.Row="2"
                           Text="Friends List"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#777"
                           Margin="0,0,0,15"/>

                <ListBox x:Name="ListBoxFriends"
                         Grid.Row="3"
                         FontSize="15"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource CardListBoxItemStyle}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>