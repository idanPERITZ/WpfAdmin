<Window x:Class="WpfAdminPeritz.User_AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New User"
        Height="380"
        Width="500"
        Background="#111"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="12"
            Background="#1A1A1A"
            BorderBrush="#333"
            BorderThickness="1">

        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Add New User"
                       Grid.Row="0"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,30"/>

            <!-- Username -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Username"
                           FontSize="12"
                           Foreground="#888"
                           Margin="0,0,0,6"/>
                <Border Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#333"
                        BorderThickness="1">
                    <TextBox x:Name="TxtUsername"
                             Text="{Binding UserName}"
                             Height="40"
                             FontSize="14"
                             Padding="12,0"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Email -->
            <StackPanel Grid.Row="2" Margin="0,0,0,30">
                <TextBlock Text="Email"
                           FontSize="12"
                           Foreground="#888"
                           Margin="0,0,0,6"/>
                <Border Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#333"
                        BorderThickness="1">
                    <TextBox x:Name="TxtEmail"
                             Text="{Binding Email}"
                             Height="40"
                             FontSize="14"
                             Padding="12,0"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="110" Height="40"
                        Margin="0,0,10,0"
                        Background="#252525"
                        Foreground="#888"
                        FontSize="14"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Save"
                        Width="110" Height="40"
                        Background="White"
                        Foreground="Black"
                        FontSize="14"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSave_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>