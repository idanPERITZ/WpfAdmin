<UserControl x:Class="WpfAdminPeritz.Users_UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8">

    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="520"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Players List"
                   Grid.Row="0" Grid.ColumnSpan="3"
                   FontSize="28" FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="10,0,0,20"/>

        <!-- SPACER: keeps left list aligned with right panel -->
        <StackPanel Grid.Row="1" Grid.Column="0" Height="55"/>

        <!-- ACTION BUTTONS -->
        <StackPanel Grid.Row="1" Grid.Column="1"
                    Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="New User ➕"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ButtonNew_Click"/>
            <Button Content="Update ✏️"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ButtonUpdate_Click"/>
            <Button Content="Delete 🗑️"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ButtonDelete_Click"/>
        </StackPanel>

        <!-- LEFT SIDE USERS LIST -->
            <Border Grid.Row="2" Grid.Column="0"
                Background="White" CornerRadius="10"
                Padding="0" Margin="10,0,10,0">
            <ListBox x:Name="ListBoxUsers"
                     FontSize="15" BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                     SelectionChanged="ListBox_SelectionChanged"
                     RequestBringIntoView="ListBoxUsers_RequestBringIntoView"/>
        </Border>

        <!-- RIGHT SIDE -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="White" CornerRadius="10" Padding="30">
            <StackPanel x:Name="StackPanelUserView">

                <TextBlock Text="User Details"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Email" FontSize="14" Foreground="#777"/>
                <TextBlock Text="{Binding Email}"
                           FontSize="16" FontWeight="SemiBold"/>

                <Separator Margin="0,15"/>

                <TextBlock Text="Username" FontSize="14" Foreground="#777"/>
                <TextBlock Text="{Binding UserName}"
                           FontSize="16" FontWeight="SemiBold"/>

                <Separator Margin="0,15"/>

                <TextBlock Text="User Type" FontSize="14" Foreground="#777"/>
                <TextBlock Text="{Binding UserType}"
                           FontSize="16" FontWeight="SemiBold"/>

                <Separator Margin="0,15"/>

                <TextBlock Text="Date Joined" FontSize="14" Foreground="#777"/>
                <TextBlock Text="{Binding DateJoined, StringFormat='dd/MM/yyyy'}"
                           FontSize="16" FontWeight="SemiBold"/>

                <Separator Margin="0,15"/>

                <!-- Games Played Label -->
                <TextBlock Text="Games Played"
                           FontSize="14" Foreground="#777"/>

                <!-- Stats Row: Wins / Draws / Losses -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">

                    <!-- Wins -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Wins}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#27AE60"
                                   HorizontalAlignment="Center"
                                   ToolTip="Wins"/>
                        <TextBlock Text="W"
                                   FontSize="11" Foreground="#27AE60"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Separator -->
                    <TextBlock Text=" / "
                               FontSize="22" FontWeight="Bold"
                               Foreground="#555"
                               VerticalAlignment="Center"/>

                    <!-- Draws -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Draws}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   ToolTip="Draws"/>
                        <TextBlock Text="D"
                                   FontSize="11" Foreground="#888"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Separator -->
                    <TextBlock Text=" / "
                               FontSize="22" FontWeight="Bold"
                               Foreground="#555"
                               VerticalAlignment="Center"/>

                    <!-- Losses -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Losses}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#E74C3C"
                                   HorizontalAlignment="Center"
                                   ToolTip="Losses"/>
                        <TextBlock Text="L"
                                   FontSize="11" Foreground="#E74C3C"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>