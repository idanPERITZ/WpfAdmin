<Window x:Class="WpfAdminPeritz.User_UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update User"
        Height="550"
        Width="661"
        Background="#181818"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style TargetType="TextBlock"
               x:Key="HeaderStyle">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="36"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="Margin"
                    Value="0,0,0,40"/>

            <Setter Property="HorizontalAlignment"
                    Value="Center"/>

        </Style>

        <Style TargetType="Button"
               x:Key="MainButtonStyle">

            <Setter Property="Background"
                    Value="#65A63F"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="20"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Height"
                    Value="55"/>

            <Setter Property="Width"
                    Value="350"/>

            <Setter Property="Margin"
                    Value="0,20,0,0"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <Style TargetType="TextBox"
               x:Key="TextInputStyle">

            <Setter Property="Height"
                    Value="55"/>

            <Setter Property="Width"
                    Value="350"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="16"/>

            <Setter Property="Background"
                    Value="#252525"/>

            <Setter Property="BorderBrush"
                    Value="#353535"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Padding"
                    Value="50,0,10,0"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

            <Setter Property="Margin"
                    Value="0,10,0,10"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Grid>

                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">

                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"
                                              VerticalAlignment="Center"/>

                            </Border>

                            <!-- USER ICON -->

                            <Path x:Name="UserIcon"
                                  Data="M12,12C14.21,12 16,10.21 16,8C16,5.79 14.21,4 12,4C9.79,4 8,5.79 8,8C8,10.21 9.79,12 12,12ZM12,14C9.33,14 4,15.34 4,18V20H20V18C20,15.34 14.67,14 12,14Z"
                                  Fill="#A9A9A9"
                                  Width="20"
                                  Height="20"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="15,0,0,0"
                                  Visibility="Collapsed"/>

                            <!-- EMAIL ICON -->

                            <Path x:Name="EmailIcon"
                                  Data="M20,4H4C2.9,4 2.01,4.9 2.01,6L2,18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V6C22,4.9 21.1,4 20,4ZM20,8L12,13L4,8V6L12,11L20,6V8Z"
                                  Fill="#A9A9A9"
                                  Width="20"
                                  Height="20"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="15,0,0,0"
                                  Visibility="Collapsed"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="Tag"
                                     Value="Username">

                                <Setter TargetName="UserIcon"
                                        Property="Visibility"
                                        Value="Visible"/>

                            </Trigger>

                            <Trigger Property="Tag"
                                     Value="Email">

                                <Setter TargetName="EmailIcon"
                                        Property="Visibility"
                                        Value="Visible"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">

            <TextBlock Text="Update User"
                       Style="{StaticResource HeaderStyle}"/>

            <TextBox x:Name="UsernameTextBox"
                     Tag="Username"
                     Text="{Binding UserName}"
                     Style="{StaticResource TextInputStyle}"/>

            <TextBox x:Name="EmailTextBox"
                     Tag="Email"
                     Text="{Binding Email}"
                     Style="{StaticResource TextInputStyle}"/>

            <Button Content="Save Changes"
                    Style="{StaticResource MainButtonStyle}"
                    Click="BtnSave_Click"/>

        </StackPanel>

    </Grid>

</Window>